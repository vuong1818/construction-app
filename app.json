{
  "expo": {
    "name": "Nguyen MEP On-Site Tech",
    "slug": "nguyenmep-onsite-tech",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "onsitetech",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nguyenmep.onsitetech",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of job site progress, receipts, and safety conditions.",
        "NSPhotoLibraryUsageDescription": "Attach photos from your library to projects, expenses, and safety records.",
        "NSPhotoLibraryAddUsageDescription": "Save signed acknowledgement PDFs and job photos to your library.",
        "NSLocationWhenInUseUsageDescription": "Verify you are on the job site when you clock in or out.",
        "NSMicrophoneUsageDescription": "Record audio when capturing video on the job site.",
        "ITSAppUsesNonExemptEncryption": false,
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.nguyenmep.onsitetech",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "Take photos of job site progress, receipts, and safety conditions."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Attach photos from your library to projects, expenses, and safety records."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Verify you are on the job site when you clock in or out."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e83f0eec-5ab7-4d51-9cce-27e5c058545c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e83f0eec-5ab7-4d51-9cce-27e5c058545c"
    }
  }
}
